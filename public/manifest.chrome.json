{
  "manifest_version": 3,
  "name": "Sidenotes V2",
  "version": "1.0.0",
  "description": "A polished sticky-notes app in the Chrome side panel. Create, organize, and search notes without leaving your browser.",
  "permissions": ["storage", "sidePanel"],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "Sidenotes V2",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
